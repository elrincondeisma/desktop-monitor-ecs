{
  "name": "desktop-monitor-ecs",
  "version": "1.3.1",
  "description": "Monitor de AWS ECS en la barra de menú: clusters, servicios, tareas e instancias",
  "author": "Ismael Catala <ismael@elrincondeisma.com>",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "gen-icons": "node scripts/gen-icons.js && node scripts/gen-appicon.js",
    "pack": "electron-builder --mac --dir",
    "dist": "electron-builder --mac",
    "release": "npm version patch && git push origin main --follow-tags",
    "release:minor": "npm version minor && git push origin main --follow-tags",
    "release:major": "npm version major && git push origin main --follow-tags"
  },
  "license": "MIT",
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.smileandlearn.desktopmonitorecs",
    "productName": "ECS Monitor",
    "copyright": "© 2026 Ismael Catala",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "identity": null,
      "artifactName": "ECSMonitor-${version}-${arch}.${ext}",
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "publish": {
      "provider": "github"
    }
  },
  "dependencies": {
    "@aws-sdk/client-ecs": "^3.700.0",
    "@aws-sdk/client-s3": "^3.1069.0",
    "@aws-sdk/credential-providers": "^3.700.0",
    "@aws-sdk/shared-ini-file-loader": "^3.374.0"
  }
}
