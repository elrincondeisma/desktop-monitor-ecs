{
  "name": "desktop-monitor-ecs",
  "version": "0.1.0",
  "description": "Monitor de AWS ECS en la barra de menú: clusters, servicios, tareas e instancias",
  "author": "Smile and Learn <smileandlearndigitalcreations@gmail.com>",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "gen-icons": "node scripts/gen-icons.js && node scripts/gen-appicon.js",
    "pack": "electron-builder --mac --dir",
    "dist": "electron-builder --mac"
  },
  "license": "MIT",
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.smileandlearn.desktopmonitorecs",
    "productName": "ECS Monitor",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        { "target": "dmg", "arch": ["universal"] },
        { "target": "zip", "arch": ["universal"] }
      ],
      "identity": null,
      "artifactName": "ECSMonitor-${version}-${arch}.${ext}",
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "publish": {
      "provider": "github"
    }
  },
  "dependencies": {
    "@aws-sdk/client-ecs": "^3.700.0",
    "@aws-sdk/credential-providers": "^3.700.0",
    "@aws-sdk/shared-ini-file-loader": "^3.374.0"
  }
}
